<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <!-- This project sits at the repo root, so its default source glob would otherwise
         pull in the sibling test project. Keep those files out of the main compile. -->
    <Compile Remove="FriedChickenScript.Tests/**/*.cs" />
  </ItemGroup>

</Project>
