{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "FriedChicken Script",
  "scopeName": "source.fc",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#constants" },
    { "include": "#declarations" },
    { "include": "#keywords" },
    { "include": "#function_calls" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.fc", "match": "//.*$" },
        { "name": "comment.block.fc", "begin": "/\\*", "end": "\\*/" }
      ]
    },
    "strings": {
      "name": "string.quoted.double.fc",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.fc", "match": "\\\\." }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.fc", "match": "\\b[0-9]+\\b" }
      ]
    },
    "constants": {
      "patterns": [
        { "name": "constant.language.fc", "match": "\\b(COOKED|RAW|EMPTY)\\b" }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "match": "\\b(bucket)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.fc" },
            "2": { "name": "entity.name.type.fc" }
          }
        },
        {
          "match": "\\b(recipe)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.fc" },
            "2": { "name": "entity.name.function.fc" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.fc",
          "match": "\\b(if|else|fryWhile|serve|orderUp|withExtra)\\b"
        },
        {
          "name": "storage.type.fc",
          "match": "\\b(ingredient|recipe|bucket|secretSpice)\\b"
        }
      ]
    },
    "function_calls": {
      "patterns": [
        {
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": { "1": { "name": "entity.name.function.fc" } }
        }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.fc", "match": "==|!=|>=|<=|&&|\\|\\||[-+*/<>=.!]" }
      ]
    }
  }
}
