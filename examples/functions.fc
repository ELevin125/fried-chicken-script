// Recipes: parameters, serve (return), recursion, and return from inside an if

recipe addStuff withSides: a, b {
    serve a + b
}

recipe factorial withSides: n {
    if (n < 2) {
        serve 1
    }
    serve n * factorial(n - 1)
}

orderUp(addStuff(3, 4))    // 7
orderUp(factorial(5))      // 120
