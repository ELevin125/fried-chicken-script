// Variables, arithmetic, strings, and constants

ingredient x = 5
ingredient y = x + 3
ingredient z = x * y
orderUp(z)                        // 40

orderUp("Hello " + "chicken")     // Hello chicken

ingredient spicy = COOKED
orderUp(spicy)                    // COOKED

// Precedence + associativity
orderUp(2 + 3 * 4)                // 14
orderUp(10 - 2 - 3)               // 5
